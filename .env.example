# ─── DATABASE (SUPABASE) ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── REDIS (BULLMQ / CACHING) ──────────────────────────────────────────────
REDIS_URL=redis://default:password@your-redis-host:6379

# ─── AUTHENTICATION (JWT) ──────────────────────────────────────────────────
JWT_SECRET=your-32-char-random-string
JWT_REFRESH_SECRET=another-random-string
FRONTEND_URL=http://localhost:3000

# ─── PAYMENTS (PAYSTACK) ───────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ─── NOTIFICATIONS (Termii / FlashSMS / WhatsApp / FCM) ──────────────────────
# Auth SMS
TERMII_API_KEY=
TERMII_SENDER_ID=TaskGH

# Class 0 Important/Booking SMS
FLASHSMS_API_KEY=
FLASHSMS_SENDER_ID=TaskGH

# Real-time WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
ADMIN_ALERT_PHONE=+233...

# Firebase Cloud Messaging
GOOGLE_APPLICATION_CREDENTIALS=./firebase-admin-key.json

# ─── MEDIA (CLOUDINARY) ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── MONITORING (SENTRY) ───────────────────────────────────────────────────
SENTRY_DSN=
NODE_ENV=development
PORT=5000
ENABLE_CRONS=true
