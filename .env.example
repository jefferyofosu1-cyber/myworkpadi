# ─── DATABASE (SUPABASE) ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres


# ─── AUTHENTICATION (JWT) ──────────────────────────────────────────────────
JWT_SECRET=your-32-char-random-string
JWT_REFRESH_SECRET=another-random-string
FRONTEND_URL=http://localhost:3000

# ─── NOTIFICATIONS (FlashSMS / WhatsApp / FCM) ──────────────────────
# Class 0 Important/Booking SMS
FLASHSMS_API_KEY=bms_live_6c5118b8c6baf6c37200a562743a105a8cf0bbba69ca6ebe5755adfb86cf0e90
FLASHSMS_SENDER_ID=TaskGH

# Real-time WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
ADMIN_ALERT_PHONE=+233...

# Firebase Cloud Messaging
GOOGLE_APPLICATION_CREDENTIALS=./firebase-admin-key.json

# ─── MEDIA (CLOUDINARY) ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── MONITORING (SENTRY) ───────────────────────────────────────────────────
SENTRY_DSN=
NODE_ENV=development
PORT=5000
ENABLE_CRONS=true
